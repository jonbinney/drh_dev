#!/usr/bin/bash
set -e

BOARD_SIZE=5
MAX_WALLS=1
MAX_STEPS=16

NUM_THREADS=10

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
ROOT_DIR=$SCRIPT_DIR/..

cd $ROOT_DIR


OUTPUT_DB_PATH=policydb_${BOARD_SIZE}_${MAX_WALLS}_${MAX_STEPS}.parquet

(cd deep_quoridor/rust && cargo build --bin create_policy_db --release --all-features)

rm -f $OUTPUT_DB_PATH || true # Delete any old existing database

/usr/bin/time ./deep_quoridor/rust/target/release/create_policy_db \
    --board-size ${BOARD_SIZE} --max-walls ${MAX_WALLS} --max-steps ${MAX_STEPS} \
    --num-threads ${NUM_THREADS} \
    --output $OUTPUT_DB_PATH

ls -alh $OUTPUT_DB_PATH

